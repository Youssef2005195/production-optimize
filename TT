<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<title>AI Production Optimizer</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
body {
    font-family: Arial;
    background: linear-gradient(135deg, #1e3c72, #2a5298);
    color: white;
    text-align: center;
}

.container {
    width: 85%;
    margin: auto;
    padding: 20px;
    border-radius: 15px;
    backdrop-filter: blur(10px);
    background: rgba(255,255,255,0.1);
}

h1 {
    margin-bottom: 10px;
}

.kpi {
    font-size: 18px;
    margin: 6px;
}

.highlight {
    color: #00ffcc;
    font-weight: bold;
}

.warning {
    color: #ff4d4d;
    font-weight: bold;
}

input {
    width: 60%;
}

button {
    margin: 5px;
    padding: 10px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
}
</style>
</head>

<body>

<h1>🤖 AI Production Optimization Dashboard</h1>

<div class="container">

<p>🎚️ اختر سرعة الإنتاج:</p>
<input type="range" min="1" max="100" value="50" id="slider">

<p class="kpi">🚀 السرعة: <span id="speed"></span></p>
<p class="kpi">⚠️ العيوب: <span id="defects"></span></p>
<p class="kpi">💰 الخسائر: <span id="loss"></span></p>
<p class="kpi highlight">🎯 Optimal Speed: <span id="optimal"></span></p>

<div>
<button onclick="scenario(0.3,0.08)">Low Risk</button>
<button onclick="scenario(0.5,0.1)">Medium</button>
<button onclick="scenario(0.9,0.2)">High</button>
<button onclick="autoOptimize()">⚡ Auto Optimize</button>
</div>

<canvas id="chart"></canvas>

</div>

<script>
let a = 0.5;
let b = 0.1;

const ctx = document.getElementById("chart").getContext("2d");

let speeds = [];
let defectsData = [];
let lossData = [];
let optimalSpeed = 0;

function generate() {
    speeds = [];
    defectsData = [];
    lossData = [];

    for (let i = 1; i <= 100; i++) {
        speeds.push(i);
        defectsData.push(a * i);
        lossData.push(b * i * i);
    }
}

function findOptimal() {
    let min = Infinity;

    for (let i = 1; i <= 100; i++) {
        let loss = b * i * i;
        if (loss < min) {
            min = loss;
            optimalSpeed = i;
        }
    }
}

generate();
findOptimal();

const verticalLinePlugin = {
    id: 'verticalLine',
    afterDraw(chart) {
        const x = chart.scales.x.getPixelForValue(optimalSpeed);
        const ctx = chart.ctx;

        ctx.save();
        ctx.beginPath();
        ctx.moveTo(x, 0);
        ctx.lineTo(x, chart.height);
        ctx.strokeStyle = "yellow";
        ctx.lineWidth = 2;
        ctx.stroke();
        ctx.restore();
    }
};

const pointPlugin = {
    id: 'pointHighlight',
    afterDatasetsDraw(chart) {
        const meta = chart.getDatasetMeta(1);
        const point = meta.data[optimalSpeed - 1];
        const ctx = chart.ctx;

        ctx.save();
        ctx.beginPath();
        ctx.arc(point.x, point.y, 6, 0, 2 * Math.PI);
        ctx.fillStyle = "red";
        ctx.fill();
        ctx.restore();
    }
};

let chart = new Chart(ctx, {
    type: "line",
    data: {
        labels: speeds,
        datasets: [
            {
                label: "Defects",
                data: defectsData,
                borderWidth: 2
            },
            {
                label: "Loss",
                data: lossData,
                borderWidth: 2
            }
        ]
    },
    options: {
        plugins: {
            legend: {
                labels: {
                    color: "white"
                }
            }
        },
        scales: {
            x: { ticks: { color: "white" } },
            y: { ticks: { color: "white" } }
        }
    },
    plugins: [verticalLinePlugin, pointPlugin]
});

const slider = document.getElementById("slider");

function update() {
    let s = parseInt(slider.value);

    let d = a * s;
    let l = b * s * s;

    document.getElementById("speed").innerText = s;
    document.getElementById("defects").innerText = d.toFixed(2);
    document.getElementById("loss").innerText = l.toFixed(2);
    document.getElementById("optimal").innerText = optimalSpeed;

    if (s > optimalSpeed) {
        document.getElementById("loss").className = "warning";
    } else {
        document.getElementById("loss").className = "";
    }
}

function scenario(newA, newB) {
    a = newA;
    b = newB;

    generate();
    findOptimal();

    chart.data.datasets[0].data = defectsData;
    chart.data.datasets[1].data = lossData;
    chart.update();

    update();
}

function autoOptimize() {
    slider.value = optimalSpeed;
    update();
}

slider.oninput = update;

update();
</script>

</body>
</html>
